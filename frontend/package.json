{
  "name": "PPT-Narrator",
  "private": true,
  "version": "1.0.0",
  "description": "PPT Narrator - AI-powered presentation and dual-screen teleprompter",
  "author": "Kindbgen",
  "homepage": "https://github.com/ppt-narrator/ppt-narrator",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac && bash scripts/fix-mac-signing.sh release/mac-arm64/PPT\\ Narrator.app",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "cheerio": "^1.2.0",
    "idb-keyval": "^6.2.4",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "reveal.js": "^6.0.1",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.0"
  }
}
